{
  "nodeModulesDir": "auto",
  "imports": {
    "@db/sqlite": "jsr:@db/sqlite@^0.12.0",
    "@discordjs/voice": "npm:@discordjs/voice@^0.19.0",
    "@libsql/client": "npm:@libsql/client@^0.15.0",
    "@libsql/client/web": "npm:@libsql/client@^0.15.0/web",
    "discord.js": "npm:discord.js@^14.16.0",
    "opusscript": "npm:opusscript@^0.1.1",
    "tweetnacl": "npm:tweetnacl@^1.0.3",
    "youtubei.js": "npm:youtubei.js@^17.0.0"
  },
  "tasks": {
    "start": "deno run --allow-all --env-file=.env src/index.js",
    "dev": "deno run --allow-all --env-file=.env --watch src/index.js",
    "deploy": "deno run --allow-all --env-file=.env src/deployCommands.js"
  }
}
