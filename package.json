{
  "name": "music-bot",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "node --watch src/index.js",
    "deploy": "node src/deployCommands.js",
    "test": "bun test",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "build": "bun build src/index.js --target=node --format=esm --outfile=dist/index.js --external @discordjs/opus --external ffmpeg-static --external @snazzah/davey --external @snazzah/davey-linux-x64-musl --external @snazzah/davey-linux-x64-gnu --external better-sqlite3 --external sodium-native"
  },
  "dependencies": {
    "@discordjs/opus": "^0.9.0",
    "@discordjs/voice": "^0.19.0",
    "better-sqlite3": "^12.11.1",
    "discord.js": "^14.16.0",
    "dotenv": "^16.0.0",
    "ffmpeg-static": "^5.2.0",
    "mysql2": "^3.11.0",
    "sodium-native": "^5.1.0",
    "youtube-sr": "^4.3.11",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/better-sqlite3": "^7.6.13"
  }
}
